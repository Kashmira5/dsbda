import nltk
from nltk.tokenize import word_tokenize
from nltk.corpus import stopwords
from nltk.stem import PorterStemmer, WordNetLemmatizer
from nltk import pos_tag
from sklearn.feature_extraction.text import TfidfVectorizer
nltk.download('punkt')
nltk.download('stopwords')
nltk.download('averaged_perceptron_tagger')
nltk.download('wordnet')
text = "Text analytics is used to extract useful information from text datatokens = word_tokenize(text)
print(tokens)
print(pos_tag(tokens))
stop_words = set(stopwords.words('english'))
filtered = [w for w in tokens if w.lower() not in stop_words]
print(filtered)
ps = PorterStemmer()
print([ps.stem(w) for w in filtered])
lem = WordNetLemmatizer()
print([lem.lemmatize(w) for w in filtered])
docs = [
"text analytics is useful",
"data analysis is important",
"text data is used"
]
tfidf = TfidfVectorizer()
result = tfidf.fit_transform(docs)
print(tfidf.get_feature_names_out())
print(result.toarray())
